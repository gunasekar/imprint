#!/usr/bin/env bash
# imprint — turn Markdown into branded, typeset PDFs: the specs, design docs, and
# reports that need to look official. One command gives a title page (or a title
# masthead), a running header and footer, and a consistent house style, with your
# content flowed straight through. A fixed pandoc -> Typst pipeline is
# deterministic — the same input produces the same PDF, on any machine.
#
# Usage:
#   imprint INPUT.md [-o OUT.pdf]
#          [--title T] [--subtitle S] [--desc D] [--author A] [--footer-text TEXT]
#          [--recipient R] [--date D] [--category C] [--accent #HEX]
#          [--logo PATH | --no-logo] [--logo-dark-bg PATH] [--logo-height PT]
#          [--cover | --no-cover] [--cover-style light|gradient] [--gradient]
#          [--confidential | --no-confidential] [--keep-h1] [--template PATH]
#          [--profile NAME | --list-profiles | --conventions]
#
# imprint keeps two things apart. HOUSE STYLE — the theme accent, fonts, your logo,
# and the default cover / confidential toggles — lives in a config file: a reusable
# house style you set once and apply to every document. DOCUMENT metadata — title,
# author, footer text, recipient, date — lives in the document's front matter (or a
# CLI flag above). Each document overrides only what it needs; see
# config.example.yaml.
#
# For multiple house styles (e.g. one per org), keep a named config ("profile") at
# ~/.config/imprint/profiles/<name>.yaml and select it with --profile <name> (or
# set a default with IMPRINT_PROFILE); --list-profiles prints what you have. A
# profile's logo path resolves next to the profile, so each profile's assets live
# together.
#
# Custom layout: the bundled template (templates/default.typ) is the default, but a
# `template:` key (config / front matter) or --template PATH selects another .typ —
# resolved like the logo (next to the config for a config value, next to the .md for
# front matter). A custom template gets every variable below, plus any extra scalar
# key you put in front matter or config: unrecognized keys are passed straight
# through to the template as variables, so a new template field needs no engine
# change — just author the .typ and set the field. (Identifier-like keys only:
# letters, digits, underscore.)
#
# Precedence: CLI flag > front matter (document) > config (house style) > default.
# No cover by default — the first page opens with a title masthead and the running
# header begins on page 2; --cover adds a separate title page. Output defaults to
# <input>.pdf; the title defaults to the first H1 (stripped unless --keep-h1).
# Config lookup (first found wins): --profile, $IMPRINT_CONFIG, IMPRINT_PROFILE,
# ~/.config/imprint/config.yaml, ./config.yaml.

set -euo pipefail

# Resolve the real repo dir even when invoked through a symlink (e.g. make install).
SOURCE="${BASH_SOURCE[0]}"
while [ -h "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ $SOURCE != /* ]] && SOURCE="$DIR/$SOURCE"
done
HERE="$(cd -P "$(dirname "$SOURCE")" && pwd)"
ASSETS="$HERE/assets"
TEMPLATES="$HERE/templates"

# User config home. Named house styles ("profiles" — e.g. one per org) live under
# profiles/ here, selected with --profile / IMPRINT_PROFILE. Config is resolved
# after arg parsing (below), since --profile names a profile file.
CONFIG_HOME="$HOME/.config/imprint"
PROFILES_DIR="$CONFIG_HOME/profiles"
CONFIG=""

# Output is per-run (CLI only). Everything else can come from front matter or
# config; CLI flags, when given, override both. Empty = "not set on CLI".
IN=""; OUT=""
TITLE=""; SUBTITLE=""; DESC=""; AUTHOR=""; FOOTER_TEXT_CLI=""
RECIPIENT=""; DATE=""; CONF=""; KEEP_H1=0; COVER=""; CATEGORY=""; ACCENT=""; LOGO_CLI=""; LOGO_HEIGHT_CLI=""
COVER_STYLE=""; LOGO_DARK_BG_CLI=""; NO_LOGO=0; PROFILE_CLI=""; LIST_PROFILES=0; SHOW_CONVENTIONS=0; TEMPLATE_CLI=""

usage() {
  sed -n '2,28p' "$SOURCE" | sed 's/^# \{0,1\}//'
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help) usage; exit 0;;
    -o) OUT="$2"; shift 2;;
    --title) TITLE="$2"; shift 2;;
    --subtitle) SUBTITLE="$2"; shift 2;;
    --desc) DESC="$2"; shift 2;;
    --author) AUTHOR="$2"; shift 2;;
    --footer-text) FOOTER_TEXT_CLI="$2"; shift 2;;
    --recipient) RECIPIENT="$2"; shift 2;;
    --date) DATE="$2"; shift 2;;
    --category) CATEGORY="$2"; shift 2;;
    --accent) ACCENT="$2"; shift 2;;
    --logo) LOGO_CLI="$2"; shift 2;;
    --logo-dark-bg) LOGO_DARK_BG_CLI="$2"; shift 2;;
    --no-logo) NO_LOGO=1; shift;;
    --logo-height) LOGO_HEIGHT_CLI="$2"; shift 2;;
    --profile) PROFILE_CLI="$2"; shift 2;;
    --template) TEMPLATE_CLI="$2"; shift 2;;
    --list-profiles) LIST_PROFILES=1; shift;;
    --conventions) SHOW_CONVENTIONS=1; shift;;
    --cover) COVER=1; shift;;
    --no-cover) COVER=0; shift;;
    --cover-style) COVER_STYLE="$2"; shift 2;;
    --gradient) COVER_STYLE=gradient; shift;;            # gradient look (pair with --cover)
    --no-gradient) COVER_STYLE=light; shift;;
    --confidential) CONF=1; shift;;
    --no-confidential) CONF=0; shift;;
    --keep-h1) KEEP_H1=1; shift;;
    -*) echo "unknown flag: $1" >&2; exit 2;;
    *) IN="$1"; shift;;
  esac
done

# --list-profiles: print the available profiles and exit (no input needed).
if [[ "$LIST_PROFILES" == "1" ]]; then
  shopt -s nullglob
  found=0
  for p in "$PROFILES_DIR"/*.yaml; do
    [[ $found == 0 ]] && echo "profiles in $PROFILES_DIR:"
    found=1
    echo "  $(basename "$p" .yaml)"
  done
  [[ $found == 0 ]] && echo "no profiles yet — create $PROFILES_DIR/<name>.yaml (see config.example.yaml)"
  exit 0
fi

# --conventions: print the front-matter + authoring-conventions spec straight from
# the README (the source of truth), so the /imprint skill can inject it and always
# match the installed version. Reads the README beside this script (repo root).
if [[ "$SHOW_CONVENTIONS" == "1" ]]; then
  readme="$HERE/README.md"
  [[ -f "$readme" ]] || { echo "imprint: README not found at $readme" >&2; exit 2; }
  awk '/^## /{p=($0=="## Metadata: front matter or flags"||$0=="## Authoring conventions")} p' "$readme"
  exit 0
fi

# Resolve a profile (a named config under profiles/, e.g. one per org). An explicit
# --profile wins; otherwise IMPRINT_PROFILE sets a default for the shell. A
# named-but-missing profile is an error — fail loudly rather than render with the
# wrong branding.
PROFILE_CONFIG_CLI=""; PROFILE_CONFIG_ENV=""
if [[ -n "$PROFILE_CLI" ]]; then
  PROFILE_CONFIG_CLI="$PROFILES_DIR/$PROFILE_CLI.yaml"
  [[ -f "$PROFILE_CONFIG_CLI" ]] || { echo "imprint: no profile for --profile '$PROFILE_CLI' (expected $PROFILE_CONFIG_CLI)" >&2; exit 2; }
elif [[ -n "${IMPRINT_PROFILE:-}" ]]; then
  PROFILE_CONFIG_ENV="$PROFILES_DIR/$IMPRINT_PROFILE.yaml"
  [[ -f "$PROFILE_CONFIG_ENV" ]] || { echo "imprint: no profile for IMPRINT_PROFILE '$IMPRINT_PROFILE' (expected $PROFILE_CONFIG_ENV)" >&2; exit 2; }
fi

# Config lookup (first found wins): --profile, then an explicit $IMPRINT_CONFIG,
# then an IMPRINT_PROFILE profile, then the user default, then repo-local.
for c in "$PROFILE_CONFIG_CLI" "${IMPRINT_CONFIG:-}" "$PROFILE_CONFIG_ENV" "$CONFIG_HOME/config.yaml" "$HERE/config.yaml"; do
  [[ -n "$c" && -f "$c" ]] && { CONFIG="$c"; break; }
done

[[ -n "$IN" && -f "$IN" ]] || { echo "input markdown not found: $IN" >&2; exit 2; }
[[ -n "$OUT" ]] || OUT="${IN%.md}.pdf"

BUILD="$(mktemp -d)"
trap 'rm -rf "$BUILD"' EXIT

# ---- preprocess: config + front matter + native-MD transforms ----
# The source .md stays pure Markdown. This step reads config.yaml (flat
# key: value) and the document's front matter (FM overrides config), copies any
# logo and local images into the build dir, and rewrites native constructs:
#   ```mermaid blocks  -> SVG figure (optional `%% caption:` line -> caption)
#   <!-- pagebreak -->  -> Typst page break
# Merged metadata is written to meta.kv for the bash side to finalize.
python3 - "$IN" "$BUILD" "$KEEP_H1" "$CONFIG" <<'PY'
import sys, re, subprocess, pathlib
src, build, keep_h1, cfgpath = sys.argv[1], pathlib.Path(sys.argv[2]), sys.argv[3] == "1", sys.argv[4]

def parse_flat(text):
    # Flat `key: value` pairs — no PyYAML dependency. Skips blanks/comments and
    # strips one layer of matching quotes. Good enough for config + front matter.
    out = {}
    for line in text.splitlines():
        line = line.strip()
        if not line or line.startswith("#") or ":" not in line:
            continue
        k, v = line.split(":", 1)
        k, v = k.strip(), v.strip()
        if v and v[0] in ("'", '"'):
            # Quoted value: take what's inside the quotes; anything after the
            # closing quote (e.g. an inline `# comment`) is dropped.
            q = v[0]
            end = v.find(q, 1)
            v = v[1:end] if end != -1 else v[1:]
        elif " #" in v:
            # Unquoted value: strip a trailing inline comment.
            v = v.split(" #", 1)[0].strip()
        out[k] = v
    return out

# Config holds RENDERING settings only (theme + render defaults), never document
# metadata — see PDF_CONFIG_KEYS below.
cfg = {}
if cfgpath:
    cfgp = pathlib.Path(cfgpath)
    if cfgp.is_file():
        cfg = parse_flat(cfgp.read_text())

text = pathlib.Path(src).read_text()

# Front matter: a metadata block at the very top, in either of two forms —
#   ---            ... ---            (classic YAML fence), or
#   <!--           ... -->            (HTML comment — invisible in every viewer).
# The comment form is preferred: GitHub/VS Code render a leading `---` as a
# table or rule, whereas an HTML comment is stripped everywhere.
fm = {}
fmm = (re.match(r'^---\r?\n(.*?)\r?\n---[ \t]*\r?\n', text, re.S)
       or re.match(r'^<!--[ \t]*\r?\n(.*?)\r?\n-->[ \t]*\r?\n', text, re.S))
if fmm:
    fm = parse_flat(fmm.group(1))
    text = text[fmm.end():]

# Title: front-matter `title` wins over the first H1; the H1 is still stripped
# from the body (unless --keep-h1) so it does not duplicate the header/cover.
h1 = ""
m = re.search(r'^\#\s+(.+?)\s*$', text, re.M)
if m:
    h1 = m.group(1).strip()
    if not keep_h1:
        text = text[:m.start()] + text[m.end():]

# Merge: config contributes rendering settings + house-style defaults (theme,
# fonts, toggles, and the logo — all reusable across documents); front matter
# (document metadata + any per-doc overrides) layers on top. Document-specific
# fields — title, author, footer_text, recipient, ... — never come from config.
PDF_CONFIG_KEYS = ("accent", "font_body", "font_head", "font_mono", "cover",
                   "cover_style", "confidential", "logo", "logo_dark_bg", "logo_height",
                   "template")
merged = {k: cfg[k] for k in PDF_CONFIG_KEYS if cfg.get(k) not in (None, "")}
merged.update(fm)
if not merged.get("title") and h1:
    merged["title"] = h1
# `cover` and `cover_style` are orthogonal: `cover` decides whether a title page
# renders, `cover_style` only picks its look (light / gradient) when it does. So a
# gradient cover needs both `cover: true` (or --cover) and `cover_style: gradient`
# (or --gradient/--cover-style gradient) — the style alone never creates a cover.

# Logo assets are house style with a per-document override, so they resolve by
# origin: a front-matter `logo` is relative to the .md; a config `logo` is
# relative to the config file (the logo lives centrally, not beside each doc).
# Resolve to an absolute path here, where the origin is known; `none`/empty
# suppresses (a document can drop a config logo with `logo: none`). The CLI
# `--logo` (cwd-relative) is layered on later, in the bash side.
srcdir = pathlib.Path(src).resolve().parent
cfgdir = pathlib.Path(cfgpath).resolve().parent if cfgpath else srcdir
def resolve_asset(key):
    if key in fm:
        val, base = fm.get(key), srcdir
    elif key in cfg:
        val, base = cfg.get(key), cfgdir
    else:
        return None
    val = (val or "").strip()
    if not val or val.lower() == "none":
        return None
    p = pathlib.Path(val)
    return str(p if p.is_absolute() else base / p)
# logo/logo_dark_bg are image assets; `template` is a .typ path resolved the same
# way (next to the config for a config value, next to the .md for front matter).
for key in ("logo", "logo_dark_bg", "template"):
    resolved = resolve_asset(key)
    if resolved:
        merged[key] = resolved
    else:
        merged.pop(key, None)

# Emit recognized keys to meta.kv (bash applies CLI overrides + defaults on top).
KEYS = ("title", "subtitle", "description", "author", "date", "recipient",
        "category", "cover", "cover_style", "confidential", "accent", "logo",
        "logo_dark_bg", "font_body", "font_head", "font_mono", "footer_text",
        "logo_height", "template")
meta = {k: merged[k] for k in KEYS if merged.get(k) not in (None, "")}
(build / "meta.kv").write_text("".join(f"{k}={v}\n" for k, v in meta.items()))

# Generic passthrough: any extra scalar key — in front matter or config — that is
# not one of the recognized KEYS above is forwarded to the template as a variable.
# This lets a custom template add fields (a version, a client, an effective date)
# driven entirely by front matter, with no change to this engine. Restricted to
# identifier-like keys (a valid Typst/pandoc variable name) so stray YAML can't
# inject odd -V flags; front matter wins over config for the same key.
ident = re.compile(r'^[A-Za-z][A-Za-z0-9_]*$')
# pandoc fills these itself — never let a stray key overwrite the rendered body etc.
RESERVED_VARS = {"body", "toc", "meta"}
extra = {}
for source in (cfg, fm):
    for k, v in source.items():
        if k not in KEYS and k not in RESERVED_VARS and ident.match(k) and v not in (None, ""):
            extra[k] = v
(build / "extra.kv").write_text("".join(f"{k}={v}\n" for k, v in extra.items()))

# Local images: copy each referenced file into the build dir (resolving relative
# to the source .md, `srcdir` from above) and rewrite the link, so Typst finds it
# under --root. Remote URLs are left untouched. Non-empty alt text -> framed figure.
imgn = 0
def copy_img(match):
    global imgn
    alt, url, tail = match.group(1), match.group(2).strip(), match.group(3) or ""
    if re.match(r'^[a-z]+://', url):
        return match.group(0)
    path = url.split()[0].strip("<>")
    cand = pathlib.Path(path)
    if not cand.is_absolute():
        cand = srcdir / cand
    if not cand.is_file():
        return match.group(0)
    imgn += 1
    dest = build / f"img-{imgn}{cand.suffix}"
    dest.write_bytes(cand.read_bytes())
    return f"![{alt}](img-{imgn}{cand.suffix}){tail}"
text = re.sub(r'!\[([^\]]*)\]\(([^)]+)\)(\{[^}]*\})?', copy_img, text)

# Page breaks: an HTML comment (native Markdown, invisible elsewhere).
pb = "\n```{=typst}\n#pagebreak(weak: true)\n```\n"
text = re.sub(r'(?m)^[ \t]*<!--[ \t]*(?:pagebreak|newpage)[ \t]*-->[ \t]*$', lambda _: pb, text)

# Mermaid -> SVG (vector-crisp). A `%% caption: ...` line inside the block
# becomes the figure caption and is stripped before rendering. htmlLabels:false
# makes Mermaid emit native <text> the Typst SVG renderer can draw.
mmcfg = build / "mermaid-config.json"
font_body = meta.get("font_body", "Source Sans 3")
mmcfg.write_text('{"htmlLabels":false,"fontFamily":"%s","flowchart":{"htmlLabels":false},"themeVariables":{"fontFamily":"%s"}}' % (font_body, font_body))
n = 0
def render(match):
    global n
    n += 1
    cap, kept = "", []
    for ln in match.group(1).splitlines():
        cm = re.match(r'^\s*%%\s*caption:\s*(.+?)\s*$', ln)
        if cm and not cap:
            cap = cm.group(1).strip()
        else:
            kept.append(ln)
    mmd = build / f"mermaid-{n}.mmd"
    svg = build / f"mermaid-{n}.svg"
    mmd.write_text("\n".join(kept))
    subprocess.run(
        ["mmdc", "-i", str(mmd), "-o", str(svg), "-b", "white", "-t", "neutral",
         "-c", str(mmcfg)],
        check=True, capture_output=True,
    )
    caparg = f"[{cap}]" if cap else "none"
    return f'\n```{{=typst}}\n#figure(image("mermaid-{n}.svg", width: 100%), caption: {caparg})\n```\n'

text = re.sub(r'```mermaid\n(.*?)```', render, text, flags=re.S)
(build / "processed.md").write_text(text)
PY

# ---- merge metadata: CLI flag > front matter > config > built-in default ----
FM_title=""; FM_subtitle=""; FM_description=""; FM_author=""
FM_recipient=""; FM_date=""; FM_cover=""; FM_cover_style=""; FM_confidential=""; FM_category=""
FM_accent=""; FM_logo=""; FM_logo_dark_bg=""; FM_font_body=""; FM_font_head=""; FM_font_mono=""; FM_footer_text=""; FM_logo_height=""; FM_template=""
if [[ -f "$BUILD/meta.kv" ]]; then
  while IFS='=' read -r k v; do
    case "$k" in
      title)        FM_title="$v";;
      subtitle)     FM_subtitle="$v";;
      description)  FM_description="$v";;
      author)       FM_author="$v";;
      recipient)    FM_recipient="$v";;
      date)         FM_date="$v";;
      cover)        FM_cover="$v";;
      cover_style)  FM_cover_style="$v";;
      confidential) FM_confidential="$v";;
      category)     FM_category="$v";;
      accent)       FM_accent="$v";;
      logo)         FM_logo="$v";;
      logo_dark_bg)   FM_logo_dark_bg="$v";;
      logo_height)  FM_logo_height="$v";;
      font_body)    FM_font_body="$v";;
      font_head)    FM_font_head="$v";;
      font_mono)    FM_font_mono="$v";;
      footer_text)  FM_footer_text="$v";;
      template)     FM_template="$v";;
    esac
  done < "$BUILD/meta.kv"
fi

TITLE="${TITLE:-${FM_title}}"
SUBTITLE="${SUBTITLE:-${FM_subtitle}}"
DESC="${DESC:-${FM_description}}"
AUTHOR="${AUTHOR:-${FM_author}}"
RECIPIENT="${RECIPIENT:-${FM_recipient}}"
DATE="${DATE:-${FM_date}}"
CATEGORY="${CATEGORY:-${FM_category}}"
ACCENT="${ACCENT:-${FM_accent}}"

# Footer text: CLI flag > front-matter footer_text > author. All document-level.
FOOTER_TEXT="${FOOTER_TEXT_CLI:-${FM_footer_text:-${AUTHOR}}}"

# Boolean toggles: CLI (1/0) wins; else front matter / config; else default off.
truthy() { case "$1" in true|True|TRUE|1|yes|Yes|on) return 0;; *) return 1;; esac; }
if [[ -z "$CONF"  ]]; then truthy "$FM_confidential" && CONF=1 || CONF=0; fi

# Cover style: CLI flag > front matter / config; default "light". Only "gradient"
# is special — anything else is the light cover. The style only picks the look of
# a cover that `cover` turns on; it never creates one on its own, so `--gradient`
# (or `cover_style: gradient`) needs `--cover` / `cover: true` alongside it.
COVER_STYLE="${COVER_STYLE:-${FM_cover_style:-light}}"
[[ "$COVER_STYLE" == "gradient" ]] || COVER_STYLE=light

if [[ -z "$COVER" ]]; then truthy "$FM_cover" && COVER=1 || COVER=0; fi

# Build pandoc args incrementally (avoids empty-array expansion under bash 3.2 set -u).
COMMON=( -V title="$TITLE" )
[[ -n "$AUTHOR"      ]] && COMMON+=(-M author="$AUTHOR")
[[ -n "$DATE"       ]] && COMMON+=(-V date="$DATE")
[[ -n "$SUBTITLE"   ]] && COMMON+=(-V subtitle="$SUBTITLE")
[[ -n "$DESC"       ]] && COMMON+=(-V description="$DESC")
[[ -n "$RECIPIENT"  ]] && COMMON+=(-V recipient="$RECIPIENT")
[[ -n "$CATEGORY"   ]] && COMMON+=(-V category="$CATEGORY")
[[ -n "$ACCENT"     ]] && COMMON+=(-V accent="$ACCENT")
[[ -n "$FOOTER_TEXT" ]] && COMMON+=(-V footer_text="$FOOTER_TEXT")
[[ -n "$FM_font_body" ]] && COMMON+=(-V font_body="$FM_font_body")
[[ -n "$FM_font_head" ]] && COMMON+=(-V font_head="$FM_font_head")
[[ -n "$FM_font_mono" ]] && COMMON+=(-V font_mono="$FM_font_mono")
[[ "$CONF"  == "1" ]] && COMMON+=(-V confidential=true)
[[ "$COVER" == "1" ]] && COMMON+=(-V cover=true)
[[ "$COVER" == "1" && "$COVER_STYLE" == "gradient" ]] && COMMON+=(-V cover_style=gradient)

# Logo: the CLI flag (cwd-relative) wins; otherwise the config / front-matter
# logo already resolved by the python preprocessor to an absolute path (by origin:
# relative to the .md for front matter, relative to the config file for config).
# `--no-logo` drops the logo (and its white variant) for this run. `copy_logo`
# copies the asset into the build dir and passes the basename so Typst resolves it
# under --root. `copy_logo VAR_VALUE BUILD_BASENAME TYPST_VAR` per asset.
copy_logo() {
  local src="$1" base="$2" var="$3" path=""
  [[ -z "$src" ]] && return 0
  if [[ "$src" = /* && -f "$src" ]]; then path="$src"
  elif [[ -f "$(dirname "$IN")/$src" ]]; then path="$(dirname "$IN")/$src"
  elif [[ -f "$src" ]]; then path="$src"; fi
  if [[ -n "$path" ]]; then
    cp "$path" "$BUILD/$base.${path##*.}"
    COMMON+=(-V "$var=$base.${path##*.}")
  fi
}
LOGO="${LOGO_CLI:-${FM_logo}}"
LOGO_DARK_BG="${LOGO_DARK_BG_CLI:-${FM_logo_dark_bg}}"
if [[ "$NO_LOGO" == "1" ]]; then LOGO=""; LOGO_DARK_BG=""; fi
copy_logo "$LOGO" logo logo
# A light logo for the gradient cover; only used there (see the template).
copy_logo "$LOGO_DARK_BG" logo-dark-bg logo_dark_bg

# Logo height (cover pt). CLI flag > front matter; the template defaults to
# 40pt when unset, matching proof.
LOGO_HEIGHT="${LOGO_HEIGHT_CLI:-${FM_logo_height}}"
[[ -n "$LOGO_HEIGHT" ]] && COMMON+=(-V logo_height="$LOGO_HEIGHT")

# Generic passthrough: extra front-matter / config keys the preprocessor collected
# (everything not a recognized key) become template variables, so a custom template
# can read fields this engine has never heard of without any code change here.
if [[ -f "$BUILD/extra.kv" ]]; then
  while IFS='=' read -r k v; do
    [[ -n "$k" ]] && COMMON+=(-V "$k=$v")
  done < "$BUILD/extra.kv"
fi

# Template: --template (cwd-relative) wins; else a config / front-matter `template`
# (already resolved to an absolute path by the preprocessor); else the bundled
# default. A named-but-missing template is an error — fail loudly, don't silently
# fall back to default and render the wrong layout.
TEMPLATE_PATH="$TEMPLATES/default.typ"
TEMPLATE="${TEMPLATE_CLI:-${FM_template}}"
if [[ -n "$TEMPLATE" ]]; then
  if [[ -f "$TEMPLATE" ]]; then TEMPLATE_PATH="$TEMPLATE"
  else echo "imprint: template not found: $TEMPLATE" >&2; exit 2; fi
fi

# --columns=1 forces pandoc to translate every pipe table's dash ratios into
# explicit column widths. --wrap=none keeps it from hard-wrapping generated Typst.
pandoc "$BUILD/processed.md" -t typst --template "$TEMPLATE_PATH" \
  --columns=1 --wrap=none "${COMMON[@]}" -o "$BUILD/doc.typ"
# Fonts: the bundled families, plus an optional user font dir for custom faces a
# profile names (e.g. a brand's typeface). --ignore-system-fonts keeps the render
# deterministic — only these paths are searched, never the machine's installed
# fonts — so output depends solely on the bundled fonts and your own font dir.
FONT_PATHS=( --font-path "$ASSETS/fonts" )
[[ -d "$CONFIG_HOME/fonts" ]] && FONT_PATHS+=( --font-path "$CONFIG_HOME/fonts" )
typst compile "$BUILD/doc.typ" "$BUILD/out.pdf" --root "$BUILD" \
  "${FONT_PATHS[@]}" --ignore-system-fonts

cp "$BUILD/out.pdf" "$OUT"
echo "wrote $OUT"
